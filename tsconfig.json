{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "outDir":            "./dist",
    "rootDir":           ".",
    "lib":               ["ES2020", "DOM", "DOM.Iterable"],
    "sourceMap":         true,
    "declaration":       true
  },
  "include":  ["**/*.ts"],
  "exclude":  ["node_modules", "dist"]
}
